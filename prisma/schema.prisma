generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model user {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String   @unique
  hashedPassword String
  emailVerified  Boolean  @default(false)
  role           Role     @default(user)
  image          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum Role {
  user
  admin
}

model project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  thumbnail   Json
  title       String
  slug        String   @unique
  status      String
  githubLink  String
  liveLink    String
  shortDes    String
  des         Json
  projectTime DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model settings {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  reCaptcha       String
  reCaptchaOnPage String[]
  blockPage       String[]
}

model blog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  thumbnail Json
  title     String
  slug      String   @unique
  status    String
  des       Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model contact {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt   DateTime @default(now())
  fullName    String
  email       String
  phoneNumber String?
  subject     String
  details     String
}

model images {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  url       String
  alt       String?
  createdAt DateTime @default(now())
}
